# Linear API key — required for Linear MCP integration
# Get yours at: https://linear.app/settings/api
LINEAR_API_KEY=

# Linear Project ID — required for Linear backend
# Create a project in Linear UI first, then copy its ID
LINEAR_PROJECT_ID=

# Notion API key — required for Notion MCP integration
# Create an internal integration at: https://www.notion.so/my-integrations
NOTION_API_KEY=

# Notion Issues Database ID — required for Notion backend
# Create a database in Notion for issues, then copy its ID from the URL
NOTION_ISSUES_DATABASE_ID=
